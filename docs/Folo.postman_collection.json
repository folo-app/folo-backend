{
  "info": {
    "_postman_id": "6ae63680-65ee-4ec9-b020-fef266ad972f",
    "name": "FOLO Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "FOLO backend Phase 1 + Phase 2 review collection."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "email", "value": "postman@example.com" },
    { "key": "password", "value": "Password123!" },
    { "key": "verificationCode", "value": "000000" },
    { "key": "importResultId", "value": "1" },
    { "key": "reminderId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"nickname\": \"postmanUser\"\n}"
            },
            "url": "{{baseUrl}}/auth/signup"
          }
        },
        {
          "name": "Confirm Email",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"code\": \"{{verificationCode}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/email/confirm"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh"
          }
        }
      ]
    },
    {
      "name": "Phase 2",
      "item": [
        {
          "name": "Update KIS Key",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"kisAppKey\": \"PS12345678\",\n  \"kisAppSecret\": \"secret-value-1234\"\n}"
            },
            "url": "{{baseUrl}}/users/me/kis-key"
          }
        },
        {
          "name": "Create Reminder",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticker\": \"AAPL\",\n  \"market\": \"NASDAQ\",\n  \"amount\": 300000,\n  \"dayOfMonth\": 5\n}"
            },
            "url": "{{baseUrl}}/reminders"
          }
        },
        {
          "name": "List Reminders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/reminders"
          }
        },
        {
          "name": "Import CSV Preview",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "docs/examples/trades.sample.csv" },
                { "key": "broker", "type": "text", "value": "KIS" }
              ]
            },
            "url": "{{baseUrl}}/portfolio/import/csv"
          }
        },
        {
          "name": "Confirm Import",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"importResultIds\": [{{importResultId}}]\n}"
            },
            "url": "{{baseUrl}}/portfolio/import/confirm"
          }
        },
        {
          "name": "Import OCR Preview",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": "005930_KRX_BUY_10_74200_20250312101500.png"
                }
              ]
            },
            "url": "{{baseUrl}}/portfolio/import/ocr"
          }
        },
        {
          "name": "Sync Portfolio",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/portfolio/sync"
          }
        },
        {
          "name": "Get Portfolio Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/portfolio"
          }
        }
      ]
    }
  ]
}
